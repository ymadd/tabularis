{
  "name": "tabularis",
  "private": true,
  "version": "0.13.4",
  "type": "module",
  "links": {
    "discord": "https://discord.com/invite/K2hmhfHRSt",
    "github": "https://github.com/TabularisDB/tabularis",
    "x": "https://x.com/tabularisdb",
    "bluesky": "https://bsky.app/profile/tabularis.bsky.social",
    "mastodon": "https://mastodon.social/@tabularis"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cd src-tauri && cargo test",
    "test:all": "pnpm test:rust && pnpm test:coverage",
    "tauri": "tauri",
    "build:plugin-api": "pnpm --filter @tabularis/plugin-api build",
    "check:plugin-api": "pnpm --filter @tabularis/plugin-api check:sync",
    "build:create-plugin": "pnpm --filter @tabularis/create-plugin build",
    "smoke:create-plugin": "pnpm --filter @tabularis/create-plugin smoke",
    "roadmap": "node scripts/update-roadmap.js",
    "sync-links": "node scripts/sync-links.js",
    "sync-sponsors": "node scripts/sync-sponsors.js",
    "version": "node scripts/sync-version.js && conventional-changelog -p angular -i CHANGELOG.md -s && git add README.md CHANGELOG.md src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/Cargo.lock src/version.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-notification": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.10.2",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "emoji-picker-react": "^4.19.1",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "json-edit-react": "^1.29.1",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.55.1",
    "process": "^0.11.10",
    "react": "^19.2.4",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "sql-formatter": "^15.8.2",
    "util": "^0.12.5",
    "wkx": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-angular": "^8.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.30.3"
}
